# ============================================================
# Routing & OSRM
# ============================================================
# OSRM server URL (default: https://router.project-osrm.org)
# Set to http://localhost:5000 for local OSRM, or http://osrm-local:5000 in Docker
# OSRM_BASE_URL=http://localhost:5000

# ============================================================
# Event Hash (Lectura Celular)
# ============================================================
# Salt for SHA256 event hash (change in production!)
# EVENT_HASH_SALT=my-production-salt

# ============================================================
# Mercado Libre & Mercado Pago (Módulo Gerencia)
# ============================================================
# Modo mock: si es true, no requiere credenciales reales
MOCK_MERCADO_LIBRE=true
MOCK_MERCADO_PAGO=false

# Mercado Libre OAuth
# MERCADOLIBRE_CLIENT_ID=tu_client_id
# MERCADOLIBRE_CLIENT_SECRET=tu_client_secret
# MERCADOLIBRE_REDIRECT_URI=https://tudominio/api/gerencia/ml/oauth-callback

# Mercado Pago
# MERCADOPAGO_CLIENT_ID=tu_client_id
# MERCADOPAGO_CLIENT_SECRET=tu_client_secret
# MERCADOPAGO_REDIRECT_URI=https://tudominio/api/gerencia/mp/oauth-callback

