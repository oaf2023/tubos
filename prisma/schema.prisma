  ENTREGADO
  EN_PROGRESO
}

enum TipoOperacionParada {
  ENTREGA
  RETIRO
  CANJE
}

enum TipoRemito {
  ENTREGA
  DEVOLUCION
  CAMBIO
}

enum EstadoRemito {
  PENDIENTE
  COMPLETADO
  PARCIAL
}

enum TipoOperacionItemRemito {
