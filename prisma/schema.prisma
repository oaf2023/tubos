  GNC
  ELECTRICO
  HIBRIDO
  OTRO
}

enum OrientacionTubos {
  PARADOS
  ACOSTADOS
}

enum EstadoCargaVehiculo {
  ACTIVA
  COMPLETADA
  CANCELADA
}

enum TipoMantenimientoVehiculo {
  PREVENTIVO
  CORRECTIVO
  PREDICTIVO
