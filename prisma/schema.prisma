  precioUnitario        Decimal @default(0)
  bonificacionPorcentaje Decimal @default(0)
  alicuotaIva           Decimal @default(21)
  importeIva            Decimal @default(0)
  subtotal              Decimal @default(0)
  subtotalConIva        Decimal @default(0)
  articuloId            Int?
  gasId                 String?
  cylinderId            String?
  remitoItemId          String?
  pedidoItemId          String?
  mlOrderItemId         String?
