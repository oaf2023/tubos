  codigoComprobante        String   @default("00")
  abreviatura              String
  puntoVenta               String
  numero                   Int
  numeroFormateado         String
  fecha                    DateTime @default(now())
  fechaVencimiento         DateTime?
  periodoDesde             DateTime?
  periodoHasta             DateTime?
  estado                   EstadoDocumentoComercial @default(BORRADOR)
  fiscal                   Boolean  @default(false)
