  clienteCodigo            String?
  clienteNombre            String
  clienteDocumentoTipo     String?
  clienteDocumentoNumero   String?
  clienteCondicionIva      String?
  clienteDomicilio         String?
  clienteLocalidad         String?
  clienteProvincia         String?
  clientePais              String?  @default("ARGENTINA")
  clienteTelefono          String?

  moneda                   MonedaDocumento @default(ARS)
  tipoCambio               Decimal @default(1)
  listaPrecio              String?  @default("1")
  operador                 String?
  condicionVenta           String?  @default("Cuenta Corriente")

  origen                   OrigenDocumentoComercial @default(MANUAL)
  origenId                 String?
  remitoIds                String?  @default("")
  pedidoIds                String?  @default("")

  mlOrderId                String?
  mlSaleNumber             String?
  mlShipmentId             String?
  mlTrackingCode           String?
  mlBuyerName              String?
  mlBuyerDocument          String?
  mlBuyerAddress           String?

  mpPaymentId              String?
  mpPaymentMethod          String?
  mpPaymentStatus          String?
  mpPaidAmount             Decimal?

  cae                      String?
