// GasTrack AR - Control de Tubos de Gases para Soldadura
// Schema ampliado con campos normativos:
//   - ISO 18119 (inspección y recalificación)
//   - NTC 5719 (cilindros para gases - requisitos)
//   - Resolución 2876/2013 (reglamento técnico argentino)
// Base operativa: San Nicolás de los Arroyos, Buenos Aires

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gas {
  id                   String     @id @default(cuid())
  codigo               String     @unique // AR, CO2, O2, C2H2, N2, He, H2, MIX-7525, AR-HE
  nombre               String
  descripcion          String
  presionBar           Int        // Presión típica de carga del tubo
  colorHex             String     // Color de identificación (norma EN 1089-3)
  usoPrincipal         String
  categoria            String     // INERTE, ACTIVO, COMBUSTIBLE, COMBURENTE
  peligro              String     @default("GAS_PRESION") // INFLAMABLE, COMBURENTE, GAS_PRESION, NINGUNO
  precioAlquilerDiario Float?    // Tarifa de alquiler diario del tubo
  precioAlquilerMensual Float?   // Tarifa de alquiler mensual del tubo
  precioVenta          Float?    // Precio de venta del gas (carga)
  createdAt            DateTime   @default(now())
  cylinders            Cylinder[]
  alertConfig          AlertConfig?
  pedidos              Pedido[]
  stockGas             StockGas?
  movimientosStock     MovimientoStock[]
  reglaPeso            ReglaPeso?
}

model Cylinder {
  id                  String   @id @default(cuid())
  numeroSerie         String   @unique

  // ============ IDENTIFICACIÓN GENERAL ============
  propietario         String?  // Persona o empresa dueña del cilindro
  fabricante          String?  // Marca o fabricante
  paisFabricacion     String?  // País de origen
  marcaUN             Boolean  @default(false) // Símbolo UN (regulación internacional)

  // ============ ESPECIFICACIONES DE DISEÑO ============
  normaFabricacion    String?  // ISO 9809, DOT 3AA, etc.
  presionTrabajoBar   Int?     // PW - presión máxima a 15°C
  roscacilindro       String?  // 25E, 3/4-14 NGT, etc.
  espesorMinParedMm   Float?   // Espesor mínimo garantizado
  materialAleacion    String?  // Acero (H/HG), Aluminio 6061, etc.

  // ============ PESOS Y CAPACIDADES ============
  capacidadLitros     Int      // Capacidad de agua en litros
  diametroMm          Float?   // Diámetro exterior (para layout de carga)
  pesoVacioKg         Float?   // Sin válvula ni protector
  pesoTaraKg          Float?   // Vacío + válvula + solvente + masa porosa
  pesoMaxLlenadoKg    Float?   // Peso máximo de gas licuado

  // ============ INSPECCIÓN Y RECALIFICACIÓN ============
  presionEnsayoBar    Int?     // PH - presión de prueba hidrostática
  fechaEnsayoInicial  String?  // MM/AAAA
  fechaUltimoRetest   DateTime? // Última inspección periódica
  fechaProximoRetest  DateTime  // Vencimiento de recalificación
  resultadoInspeccion String   @default("APROBADO") // APROBADO | RECHAZADO | CONDENADO
  inspectorId         String?  // ID del organismo inspector
  laboratorio         String?  // Centro de revisión acreditado
  metodoPrueba        String?  // HIDROSTATICA | ULTRASONIDO | PRESION_PRUEBA

  // ============ ESPECÍFICOS DE GAS ============
  gasId               String
  gas                 Gas      @relation(fields: [gasId], references: [id])
  presionActualBar    Int      // Presión actual (0 a presionBar del gas)

  // Para acetileno
  masaPorosaId        String?  // Identificación de masa porosa interna
  tipoSolvente        String?  // ACETONA | DMF
  solventeMasaKg      Float?   // Masa de solvente en kg

  // Vida útil límite (cilindros compuestos)
  vidaUtilLimite      DateTime? // Fecha de expiración definitiva

  // Reparaciones y observaciones
  reparaciones        String?  // Detalles de reparaciones admitidas
  observaciones       String?  // Corrosión, abolladuras, daños por calor

  // ============ ESTADO OPERATIVO ============
  // LLENO, VACIO, EN_CLIENTE, EN_REPARTO, EN_CARGA, EN_DEPOSITO, MANTENIMIENTO, RETENIDO, PH_VENCIDO, BAJA, EXTRAVIADO
  estado              String   @default("LLENO")
  ubicacionLat        Float
  ubicacionLng        Float
  ubicacionNombre     String
  provincia           String
  cliente             String?  // Nombre denormalizado (búsqueda rápida)
  clienteId           String?  // Relación con tabla Clientes
  clienteRel          Cliente? @relation("ClienteCylinders", fields: [clienteId], references: [id])
  fechaCarga          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Para gases fragilizantes (H2)
  compatibleH2        Boolean  @default(false) // Estampe H o HG

  // ============ AUDITORÍA ============
  movimientos         CylinderMovimiento[]
  mantenimientos      Mantenimiento[]
  cargasVehiculo      CargaVehiculoItem[]
  tagsRFID            TagRFID[]
  lecturasPeso        LecturaPeso[]
  evidenciasFoto      EvidenciaFoto[]
  validacionesCabina   ValidacionCabina[]
  eventosTrazabilidad EventoTrazabilidad[]
  alertas             Alerta[]
  sesionesRFID        SesionLecturaRFID[]
}

model CylinderMovimiento {
  id          String   @id @default(cuid())
  cylinderId  String
  cylinder    Cylinder @relation(fields: [cylinderId], references: [id], onDelete: Cascade)
  fecha       DateTime @default(now())
  tipo        String   // CARGA, DESCARGA, TRASLADO, INSPECCION, REPARACION, ALTA, BAJA
  descripcion String
  usuario     String?
  latOrigen   Float?
  lngOrigen   Float?
  latDestino  Float?
  lngDestino  Float?
  ubicacion   String?
}

model Mantenimiento {
  id          String   @id @default(cuid())
  cylinderId  String
  cylinder    Cylinder @relation(fields: [cylinderId], references: [id], onDelete: Cascade)
  tipo        String   // CAMBIO_VALVULA, PINTURA, CAMBIO_GAS, REPARACION, INSPECCION, OTRO
  descripcion String?
  tecnico     String?
  costo       Float?
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Location {
  id        String   @id @default(cuid())
  nombre    String   @unique
  provincia String
  lat       Float
  lng       Float
  esBase    Boolean  @default(false)
  tipo      String   // BASE, CLIENTE, SUCURSAL, ALIADO
  direccion String?
  telefono  String?
  createdAt   DateTime @default(now())
}

// ============ REMITOS / ENTREGAS ============
model Remito {
  id            String       @id @default(cuid())
  numero        Int          @default(0) // Número de remito autoincremental
  clienteId     String
  cliente       String       // Nombre denormalizado
  fecha         DateTime     @default(now())
  tipo          String       // ENTREGA, DEVOLUCION, CAMBIO
  estado        String       @default("PENDIENTE") // PENDIENTE, COMPLETADO, PARCIAL
  tecnico       String?
  observaciones String?
  items         RemitoItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model RemitoItem {
  id              String   @id @default(cuid())
  remitoId        String
  remito          Remito   @relation(fields: [remitoId], references: [id], onDelete: Cascade)
  cylinderId      String?  // Cilindro entregado (nullable: entrega por gas sin tubo asignado)
  numeroSerie     String?  // Denormalizado
  gasId           String
  gasCodigo       String   // AR, O2, C2H2, etc.
  tipoOperacion   String   // ALQUILER, VENTA, CAMBIO, DEVOLUCION
  cantidad        Int      @default(1)
  fechaDevolucion DateTime? // Cuándo se devolvió
  diasAlquiler    Int?     // Calculado al facturar
  precioUnitario  Float?
  subtotal        Float?
  createdAt       DateTime @default(now())
}

// ============ FACTURACIÓN ============
model Factura {
  id               String        @id @default(cuid())
  numero           Int           @default(0) // Número de factura autoincremental
  clienteId        String
  cliente          String        // Nombre denormalizado
  fecha            DateTime      @default(now())
  fechaVencimiento  DateTime?
  fechaDesde       DateTime?     // Inicio del período facturado
  fechaHasta       DateTime?     // Fin del período facturado
  tipoPeriodo      String?       // DIARIO, MENSUAL, QUINCENAL, SEMANAL, PERSONALIZADO
  remitoIds        String        // IDs de remitos relacionados (separados por coma)
  subtotal         Float         @default(0)
  descuento        Float         @default(0)
  impuestos        Float         @default(0)
  total            Float         @default(0)
  saldoAnterior    Float         @default(0)  // Deuda previa del cliente
  notasCredito     Float         @default(0)  // Notas de crédito aplicadas
  pagosAplicados   Float         @default(0)  // Pagos recibidos
  totalGeneral     Float         @default(0)  // total + saldoAnterior - notasCredito - pagosAplicados
  estado           String        @default("PENDIENTE") // PENDIENTE, PAGADA, VENCIDA, ANULADA, BORRADOR
  observaciones    String?
  items            FacturaItem[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model FacturaItem {
  id              String   @id @default(cuid())
  facturaId       String
  factura         Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  concepto        String   // Ej: "Alquiler tubo N2 - 15 días"
  tipo            String   @default("ALQUILER") // ALQUILER, GAS, FLETE, PENALIZACION, DESCUENTO, OTRO
  remitoItemId    String?  // Link al ítem de remito origen
  cylinderId      String?  // Link al cilindro
  numeroSerie     String?  // Número de serie del cilindro
  diasFacturados  Int?     // Días de alquiler facturados
  cantidad        Int      @default(1)
  precioUnitario  Float    @default(0)
  subtotal        Float    @default(0)
  createdAt       DateTime @default(now())
}

model Cliente {
  id                    String         @id @default(cuid())
  nombre                String         @unique // Razón social
  taxId                 String?        // CUIT / Tax ID
  contacto              String?        // Persona de contacto / receptor autorizado
  firmaDigital          String?        // Registro de aceptación de responsabilidad
  tipologia             String?        // Construcción pesada, Farmacéutico, Taller, etc.
  procesoSoldadura      String?        // TIG, MIG/MAG, Oxicorte, Electrodo
  materialesBase        String?        // Acero, inox, aluminio + espesores
  parametrosIngenieria  String?        // Homologaciones WPS
  modoEnvasado          String?        // Cilindros, bloques, microgranel, granel
  gasesConsumo          String?        // Tipos de gases que consume
  serviciosEspecializados String?      // CryoEase®, Maxx®, Integra®
  nivelesStockCritico   Int?           // Stock mínimo para alertas
  contratoComodato      String?        // Número de contrato de comodato
  activosEnPosesion     String?        // IDs de cilindros en posesión
  fechaVencimientoContrato DateTime?
  historialDevoluciones String?        // Registro de activos devueltos
  cargosRecurrentes     String?        // Facturación automática
  penalizacionesExtravio String?       // Cargos por extravío
  estadoCuenta          String?        // AL_DIA, PENDIENTE, MOROSO
  ubicaciones           String?        // Direcciones / coordenadas
  lat                   Float?         // Ubicación principal latitud
  lng                   Float?         // Ubicación principal longitud
  notas                 String?
  activo                Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  cylinders             Cylinder[]     @relation("ClienteCylinders")
  acceso                ClienteAcceso?
}

model AlertConfig {
  id              String   @id @default(cuid())
  gasId           String   @unique
  gas             Gas      @relation(fields: [gasId], references: [id])
  diasAlertaRetest Int     @default(60)    // Días antes del retest para mostrar alerta
  diasMaxCliente  Int      @default(90)    // Días máximos que un cliente puede retener un tubo
  alertaPH        Boolean  @default(true)  // Mostrar alertas de prueba hidrostática
  activo          Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model Ruta {
  id           String       @id @default(cuid())
  nombre       String
  fecha        DateTime     @default(now())
  estado       String       // PLANIFICADA, EN_PROGRESO, COMPLETADA, CANCELADA
  origenNombre String
  origenLat    Float
  origenLng    Float
  distanciaKm  Float        @default(0)
  duracionHoras Float       @default(0)
  geometry     String?      // OSRM road geometry JSON: [[lat,lng],...]
  paradas      RutaParada[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model RutaParada {
  id          String  @id @default(cuid())
  rutaId      String
  ruta        Ruta    @relation(fields: [rutaId], references: [id], onDelete: Cascade)
  orden       Int
  lat         Float
  lng         Float
  nombre      String
  provincia   String
  cylinderIds String  // IDs separados por coma
  estado      String  // PENDIENTE, ENTREGADO, EN_PROGRESO
  notas       String?
  llegada     DateTime? // Timestamp de llegada real
  salida      DateTime? // Timestamp de salida real
}

model RouteCache {
  id         String   @id @default(cuid())
  hash       String   @unique // MD5-like hash of origin+dest coords
  origenLat  Float
  origenLng  Float
  destLat    Float
  destLng    Float
  distanciaKm Float
  duracionMin Int
  geometry   String   // JSON of coordinate pairs
  createdAt  DateTime @default(now())
  expiresAt  DateTime // Cache valid for 30 days
}

model Pedido {
  id              String           @id @default(cuid())
  fecha           DateTime         @default(now())
  clienteId       String?
  cliente         String           // Nombre denormalizado
  estadoCuenta    String?          // OK, DEUDA_PENDIENTE
  gasId           String
  gas             Gas              @relation(fields: [gasId], references: [id])
  operacionEnvase String           // CANJE, VENTA_NUEVO
  phVigente       Boolean?         // null si es venta nueva
  phObservacion   String?
  total           Float            @default(0)
  estado          String           @default("PENDIENTE") // PENDIENTE, COMPLETADO, CANCELADO
  observaciones   String?
  items           PedidoItem[]
  cilindros       PedidoCilindro[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model PedidoItem {
  id        String @id @default(cuid())
  pedidoId  String
  pedido    Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  concepto  String
  monto     Float
}

model TipoOperacionPedido {
  id        String   @id @default(cuid())
  nombre    String   @unique // "Con envase", "Sin envase", etc.
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PedidoCilindro {
  id          String   @id @default(cuid())
  pedidoId    String
  pedido      Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  numeroSerie String
  gasCodigo   String?  // Denormalizado: AR, O2, etc.
  verified    Boolean  @default(false) // Si el cilindro existe en inventario
  createdAt   DateTime @default(now())
}

model ClienteAcceso {
  id         String   @id @default(cuid())
  clienteId  String   @unique
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario    String   @unique
  password   String
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Rol {
  id          String    @id @default(cuid())
  nombre      String    @unique // admin, deposito, reparto, facturacion, auditor
  descripcion String?
  createdAt   DateTime  @default(now())
  usuarios    Usuario[]
}

model Usuario {
  id          String   @id @default(cuid())
  nombre      String
  direccion   String?
  telefono    String?
  ciudad      String?
  provincia   String?
  lat         Float?
  lng         Float?
  email       String?
  nivelAcceso Int      @default(1)
  usuario     String   @unique
  password    String
  activo      Boolean  @default(true)
  rolId       String?
  rol         Rol?     @relation(fields: [rolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Observacion {
  id          String              @id @default(cuid())
  tipo        String              // IMAGEN, VIDEO, NOTA, AUDIO
  titulo      String?
  descripcion String?             // texto asociado
  audioUrl    String?             // URL de audio grabado
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdBy   String?             // usuario que la creó
  archivos    ObservacionArchivo[]
}

model ObservacionArchivo {
  id             String      @id @default(cuid())
  observacionId  String
  observacion    Observacion @relation(fields: [observacionId], references: [id], onDelete: Cascade)
  tipo           String      // IMAGE, VIDEO
  nombre         String?
  datos          String      // base64 del archivo
  createdAt      DateTime    @default(now())
}

model Vehiculo {
  id                String                   @id @default(cuid())
  codigo            String                   @unique
  patente           String                   @unique
  marca             String
  modelo            String
  anio              Int
  vin               String?
  numeroMotor       String?
  tipo              String                   // AUTO, CAMIONETA, CAMION, BUS, MAQUINARIA, MONTACARGA, MOTO, OTRO
  combustible       String                   // NAFTA, GASOIL, GNC, ELECTRICO, HIBRIDO, OTRO
  capacidad         String?
  kmActual          Int                      @default(0)
  horometroActual   Int?
  estado            String                   @default("ACTIVO") // ACTIVO, EN_TALLER, BAJA, RESERVA
  areaAsignada      String?
  conductorAsignado String?
  centroCosto       String?
  fechaAdquisicion  DateTime?
  valorCompra       Float?
  vidaUtilAnios     Int?
  fechaBaja         DateTime?

  // ============ CONFIGURACIÓN DE CARGA ============
  largoCajaCm       Float?   // Largo útil de la caja
  anchoCajaCm       Float?   // Ancho útil de la caja
  altoCajaCm        Float?   // Alto útil de la caja (para orientacion PARADOS)
  maxTubos          Int?     // Capacidad máxima de tubos
  orientacionTubos  String   @default("PARADOS") // PARADOS | ACOSTADOS

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  mantenimientos    MantenimientoVehiculo[]
  cargasCombustible CargaCombustible[]
  documentos        DocumentoVehiculo[]
  sesionesCarga     CargaVehiculo[]
}

model CargaVehiculo {
  id          String               @id @default(cuid())
  vehiculoId  String
  vehiculo    Vehiculo             @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  fecha       DateTime             @default(now())
  estado      String               @default("ACTIVA") // ACTIVA, COMPLETADA, CANCELADA
  createdAt   DateTime             @default(now())
  items       CargaVehiculoItem[]
}

model CargaVehiculoItem {
  id            String         @id @default(cuid())
  cargaId       String
  carga         CargaVehiculo  @relation(fields: [cargaId], references: [id], onDelete: Cascade)
  cylinderId    String
  cylinder      Cylinder       @relation(fields: [cylinderId], references: [id])
  posicion      Int            // Número de posición en la caja (1-based)
  createdAt     DateTime       @default(now())

  @@unique([cargaId, cylinderId])
  @@unique([cargaId, posicion])
}

model MantenimientoVehiculo {
  id            String   @id @default(cuid())
  vehiculoId    String
  vehiculo      Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  tipo          String   // PREVENTIVO, CORRECTIVO, PREDICTIVO
  fecha         DateTime
  kmActual      Int?
  descripcion   String
  costo         Float?
  taller        String?
  responsable   String?
  estado        String   @default("PENDIENTE") // PENDIENTE, EN_PROCESO, COMPLETADO, CANCELADO
  observaciones String?
  createdAt     DateTime @default(now())
}

model CargaCombustible {
  id         String   @id @default(cuid())
  vehiculoId String
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  fecha      DateTime
  litros     Float
  costo      Float?
  kmActual   Int?
  rendimiento Float?
  tipo       String   @default("CARGA") // CARGA, CARGA_ELECTRICA
  createdAt  DateTime @default(now())
}

model DocumentoVehiculo {
  id               String   @id @default(cuid())
  vehiculoId       String
  vehiculo         Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  tipo             String   // REVISION_TECNICA, PERMISO_CIRCULACION, SEGURO, LICENCIA, OTRO
  numero           String?
  fechaEmision     DateTime?
  fechaVencimiento DateTime?
  estado           String   @default("VIGENTE") // VIGENTE, VENCIDO, PROXIMO_A_VENCER
  observaciones    String?
  createdAt        DateTime @default(now())
}

// ============ DEPÓSITO / RFID STOCK ============

model ZonaLectura {
  id          String   @id @default(cuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  tipo        String   // VACIOS, LLENOS, SALIDA_REPARTO, ENVIO_CARGA, RECEPCION_CARGA, MANTENIMIENTO, BAJA
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lectores    LectorIoT[]
  eventos     EventoRFID[]
  sesiones    SesionLecturaRFID[]
}

model LectorIoT {
  id            String      @id @default(cuid())
  codigo        String      @unique
  nombre        String
  tipo          String      // ESP32, RPI, GATEWAY
  ip            String?
  zonaLecturaId String
  zona          ZonaLectura @relation(fields: [zonaLecturaId], references: [id])
  activo        Boolean     @default(true)
  ultimoHeartbeat DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  eventos       EventoRFID[]
  sesiones      SesionLecturaRFID[]
}

model TagRFID {
  id                String       @id @default(cuid())
  tid               String       @unique // TID del chip RFID
  cylinderId        String?
  cylinder          Cylinder?    @relation(fields: [cylinderId], references: [id])
  fechaAsociacion   DateTime?
  activo            Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  eventos           EventoRFID[]
  sesiones          SesionLecturaRFID[]
}

model EventoRFID {
  id            String      @id @default(cuid())
  tid           String
  tag           TagRFID?    @relation(fields: [tid], references: [tid])
  cylinderId    String?
  lectorId      String
  lector        LectorIoT   @relation(fields: [lectorId], references: [id])
  zonaId        String
  zona          ZonaLectura @relation(fields: [zonaId], references: [id])
  timestamp     DateTime    @default(now())
  estadoAnterior String?
  estadoNuevo   String?
  origen        String      @default("AUTOMATICO") // AUTOMATICO, MANUAL
  usuario       String?
  observacion   String?
  createdAt     DateTime    @default(now())
  movimientosStock MovimientoStock[]
}

model SesionLecturaRFID {
  id            String      @id @default(cuid())
  lectorId      String
  lector        LectorIoT   @relation(fields: [lectorId], references: [id])
  zonaId        String
  zona          ZonaLectura @relation(fields: [zonaId], references: [id])
  tid           String      // TID del tag leído
  tag           TagRFID?    @relation(fields: [tid], references: [tid])
  cylinderId    String?
  cylinder      Cylinder?   @relation(fields: [cylinderId], references: [id])
  inicio        DateTime    @default(now())
  fin           DateTime?
  conteo        Int         @default(1) // cantidad de lecturas en esta sesión
  ultimaLectura DateTime    @default(now())
  procesado     Boolean     @default(false)
  estadoAnterior String?
  estadoNuevo   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model StockGas {
  id          String   @id @default(cuid())
  gasId       String   @unique
  gas         Gas      @relation(fields: [gasId], references: [id])
  llenos      Int      @default(0)
  vacios      Int      @default(0)
  enReparto   Int      @default(0)
  enCarga     Int      @default(0)
  mantenimiento Int    @default(0)
  baja        Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model MovimientoStock {
  id            String   @id @default(cuid())
  gasId         String
  gas           Gas      @relation(fields: [gasId], references: [id])
  tipo          String   // ENTRADA, SALIDA, TRANSFERENCIA
  cantidad      Int
  estadoAnterior String?
  estadoNuevo   String?
  eventoRfidId  String?
  eventoRfid    EventoRFID? @relation(fields: [eventoRfidId], references: [id])
  usuario       String?
  observacion   String?
  createdAt     DateTime @default(now())
}

model Reparto {
  id            String   @id @default(cuid())
  codigo        String   @unique
  fecha         DateTime @default(now())
  clienteId     String?
  cliente       String?  // Denormalizado
  vehiculoId    String?
  estado        String   @default("PENDIENTE") // PENDIENTE, EN_CURSO, COMPLETADO, CANCELADO
  origenZonaId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ CABINA INTELIGENTE ============

model Cabina {
  id          String          @id @default(cuid())
  codigo      String          @unique
  nombre      String
  ubicacion   String?
  activo      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  sensores    SensorCabina[]
  validaciones ValidacionCabina[]
  alertas     Alerta[]
  eventos     EventoTrazabilidad[]
  lecturasPeso LecturaPeso[]
  evidenciasFoto EvidenciaFoto[]
}

model SensorCabina {
  id            String   @id @default(cuid())
  cabinaId      String
  cabina        Cabina   @relation(fields: [cabinaId], references: [id], onDelete: Cascade)
  tipo          String   // RFID, BALANZA, CAMARA, UPS
  codigo        String
  configuracion String?  // JSON con config específica
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LecturaPeso {
  id          String   @id @default(cuid())
  cabinaId    String
  cabina      Cabina   @relation(fields: [cabinaId], references: [id])
  cylinderId  String?
  cylinder    Cylinder? @relation(fields: [cylinderId], references: [id])
  pesoKg      Float
  fecha       DateTime @default(now())
  sensorId    String?  // Sensor que registró la lectura
  createdAt   DateTime @default(now())
  validaciones ValidacionCabina[]
}

model EvidenciaFoto {
  id          String   @id @default(cuid())
  cabinaId    String
  cabina      Cabina   @relation(fields: [cabinaId], references: [id])
  cylinderId  String?
  cylinder    Cylinder? @relation(fields: [cylinderId], references: [id])
  fecha       DateTime @default(now())
  imagen      String   // base64
  createdAt   DateTime @default(now())
  validaciones ValidacionCabina[]
}

model ValidacionCabina {
  id              String   @id @default(cuid())
  cabinaId        String
  cabina          Cabina   @relation(fields: [cabinaId], references: [id])
  cylinderId      String?
  cylinder        Cylinder? @relation(fields: [cylinderId], references: [id])
  eventoRfidId    String?
  lecturaPesoId   String?
  lecturaPeso     LecturaPeso? @relation(fields: [lecturaPesoId], references: [id])
  evidenciaFotoId String?
  evidenciaFoto   EvidenciaFoto? @relation(fields: [evidenciaFotoId], references: [id])
  pesoRealKg      Float?
  pesoEsperadoKg  Float?
  diagnostico     String   @default("OK") // OK, INCONSISTENCIA, NO_REGISTRADO, SOSPECHOSO
  estadoFinal     String?
  alertaGenerada  Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model ReglaPeso {
  id          String   @id @default(cuid())
  gasId       String   @unique
  gas         Gas      @relation(fields: [gasId], references: [id])
  pesoMinKg   Float?
  pesoMaxKg   Float?
  pesoTaraKg  Float?
  pesoLlenoKg Float?
  updatedAt   DateTime @updatedAt
}

model EventoTrazabilidad {
  id          String   @id @default(cuid())
  cabinaId    String
  cabina      Cabina   @relation(fields: [cabinaId], references: [id])
  cylinderId  String?
  cylinder    Cylinder? @relation(fields: [cylinderId], references: [id])
  tipo        String   // PASO_CABINA, VALIDACION, ALERTA, INGRESO, EGRESO
  descripcion String?
  fecha       DateTime @default(now())
  usuario     String?
  createdAt   DateTime @default(now())
}

model Alerta {
  id          String   @id @default(cuid())
  tipo        String   // CILINDRO_NO_REGISTRADO, INCONSISTENCIA_PESO, ZONA_NO_AUTORIZADA, LECTURA_MULTIPLE, OTRO
  cabinaId    String?
  cabina      Cabina?  @relation(fields: [cabinaId], references: [id])
  cylinderId  String?
  cylinder    Cylinder? @relation(fields: [cylinderId], references: [id])
  mensaje     String
  nivel       String   // INFO, WARNING, CRITICAL
  resuelta    Boolean  @default(false)
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  accion    String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entidad   String   // Cylinder, Cliente, Pedido, Factura, Usuario, etc.
  entidadId String?  // ID del registro afectado
  usuario   String?  // usuario que ejecutó la acción
  detalle   String?  // JSON con datos relevantes del cambio
  direccionIp String?
  createdAt DateTime @default(now())
}
