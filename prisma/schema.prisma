  descripcion String
  detalle     String?
  alicuota    Decimal @default(0)
  importe     Decimal @default(0)
  createdAt   DateTime @default(now())
}

model Cliente {
  id                    String         @id @default(cuid())
  nombre                String         @unique // Razón social / Nombre de contacto
  apellido              String?        // Apellido del contacto
  email                 String?        // Correo electrónico
  telefono              String?        // Teléfono principal
  taxId                 String?        // CUIT / Tax ID
  codigoLegacy          Int?           // Código numérico en GR2 (PR_NUM)
  contacto              String?        // Persona de contacto / receptor autorizado
  telefonoSecundario    String?        // Teléfono alternativo
  fechaNacimiento       DateTime?      // Fecha de nacimiento del contacto
  genero                String?        // Masculino / Femenino / Otro
  tipoDocumento         String?        // DNI | CUIT | CUIL | Pasaporte
  numeroDocumento       String?        // Número de documento
  // Dirección estructurada
  calle                 String?
  altura                String?
  piso                  String?
  codigoPostal          String?
  ciudad                String?
  provincia             String?
  pais                  String?        @default("Argentina")
  // Datos comerciales
  empresa               String?        // Empresa a la que pertenece
  rubro                 String?        // Sector o actividad comercial
  condicionIva          String?        // ARCA: Resp.Inscripto | Monotributista | Cons.Final | Exento | Resp.No Inscripto | Sujeto No Cat. | Peq.Cont.Social | Gran Contrib.
  iibb                  String?        // Número de Ingresos Brutos
  condicionIibb         String?        // Exento | Convenio Multilateral | Local | No Corresponde
  categoriaMonotributo  String?        // A | B | C | D | E | F | G | H | I | J | K
  monotributoActividad  String?        // Servicios | Comercio | Industria
  monotributoDesde      DateTime?      // Fecha de inscripción al Monotributo
  domicilioFiscal       String?        // Domicilio fiscal (si difiere del comercial)
  limiteCredito         Float?         // Límite de crédito en ARS
  // Campos existentes
  firmaDigital          String?        // Registro de aceptación de responsabilidad
  tipologia             String?        // Construcción pesada, Farmacéutico, Taller, etc.
  procesoSoldadura      String?        // TIG, MIG/MAG, Oxicorte, Electrodo
  materialesBase        String?        // Acero, inox, aluminio + espesores
  parametrosIngenieria  String?        // Homologaciones WPS
  modoEnvasado          String?        // Cilindros, bloques, microgranel, granel
  gasesConsumo          String?        // Tipos de gases que consume
  serviciosEspecializados String?      // CryoEase®, Maxx®, Integra®
  nivelesStockCritico   Int?           // Stock mínimo para alertas
  contratoComodato      String?        // Número de contrato de comodato
  activosEnPosesion     String?        // IDs de cilindros en posesión
  fechaVencimientoContrato DateTime?
  historialDevoluciones String?        // Registro de activos devueltos
  cargosRecurrentes     String?        // Facturación automática
  penalizacionesExtravio String?       // Cargos por extravío
  estadoCuenta          EstadoCuentaCliente? // AL_DIA, PENDIENTE, MOROSO
  ubicaciones           String?        // Direcciones / coordenadas (legacy)
  lat                   Float?         // Ubicación principal latitud
  lng                   Float?         // Ubicación principal longitud
  notas                 String?
  activo                Boolean        @default(true)
  estadoCliente         EstadoCliente? @default(ACTIVO) // ACTIVO | SUSPENDIDO | INACTIVO
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  cylinders             Cylinder[]     @relation("ClienteCylinders")
  acceso                ClienteAcceso?
  paradas               RutaParada[]

  @@index([estadoCliente])
  @@index([apellido])
  @@index([ciudad])
  @@index([rubro])
}

model AlertConfig {
  id              String   @id @default(cuid())
  gasId           String   @unique
  gas             Gas      @relation(fields: [gasId], references: [id])
  diasAlertaRetest Int     @default(60)    // Días antes del retest para mostrar alerta
  diasMaxCliente  Int      @default(90)    // Días máximos que un cliente puede retener un tubo
  alertaPH        Boolean  @default(true)  // Mostrar alertas de prueba hidrostática
  activo          Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model Ruta {
  id                 String       @id @default(cuid())
  nombre             String
  fecha              DateTime     @default(now())
  estado             EstadoRuta       // PLANIFICADA, EN_PROGRESO, COMPLETADA, CANCELADA
  origenNombre       String
  origenLat          Float
  origenLng          Float
  distanciaKm        Float        @default(0)
  duracionHoras      Float        @default(0)
  geometry           String?      // OSRM road geometry JSON: [[lat,lng],...]
  costoPorKm         Float?       // Costo operativo por km (combustible + desgaste)
  costoTotal         Float?       // costoPorKm * distanciaKm (calculado)
  vehicleId          String?      // Vehículo asignado a esta ruta
  vehicle            Vehiculo?    @relation(fields: [vehicleId], references: [id])
  pedidoId           String?      // Pedido origen que generó la ruta
  cylinderIds        String?      // IDs de cilindros separados por coma (carga completa)
  navigationToken    String?      @unique // Token para compartir con el chofer (PWA)
  navigationStartedAt DateTime?  // Cuándo se inició la navegación
  conductorId        String?      // FK → Usuario (chofer asignado)
  conductor          Usuario?     @relation("ConductorRutas", fields: [conductorId], references: [id])
  isRealRoute        Boolean?     @default(false) // true si se obtuvo geometría real de OSRM
  routingSource      String?      // OSRM_LOCAL | OSRM_PUBLIC | HAVERSINE_ESTIMATED | NONE
  optimizationEngine String?      // OR_TOOLS | TSP | NONE
  paradas            RutaParada[]
  sesiones           SesionConductor[]
  ubicaciones        UbicacionGPS[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([estado])
  @@index([fecha])
  @@index([vehicleId])
  @@index([conductorId])
}

model RutaParada {
  id               String    @id @default(cuid())
  rutaId           String
  ruta             Ruta      @relation(fields: [rutaId], references: [id], onDelete: Cascade)
  orden            Int
  lat              Float
  lng              Float
  nombre           String
  provincia        String
  cylinderIds      String    // IDs separados por coma
  estado           EstadoParada     // PENDIENTE, ENTREGADO, EN_PROGRESO
  notas            String?
  llegada          DateTime? // Timestamp de llegada real
  salida           DateTime? // Timestamp de salida real
  clienteId        String?   // FK → Cliente
  cliente          Cliente?  @relation(fields: [clienteId], references: [id])
  demandaTubos     Int?      // Tubos a entregar/retirar en esta parada
  pesoKg           Float?    // Peso total estimado de la carga
  ventanaDesde     Int?      // Minutos desde 00:00 (540 = 09:00)
  ventanaHasta     Int?      // Minutos desde 00:00 (720 = 12:00)
  tiempoServicioMin Int?     // Minutos estimados en la parada
  prioridad        Int?      @default(5) // 1=urgente, 5=normal, 10=baja
  tipoOperacion    TipoOperacionParada? @default(ENTREGA) // ENTREGA, RETIRO, CANJE
  fotoUrl          String?   // Foto de entrega (data URI)
  notasConductor   String?   // Notas del conductor al entregar

  @@index([rutaId])
  @@index([estado])
  @@index([clienteId])
}

model RouteCache {
  id         String   @id @default(cuid())
  hash       String   @unique // MD5-like hash of origin+dest coords
  origenLat  Float
  origenLng  Float
  destLat    Float
  destLng    Float
  distanciaKm Float
  duracionMin Int
  geometry   String   // JSON of coordinate pairs
  createdAt  DateTime @default(now())
  expiresAt  DateTime // Cache valid for 30 days
}

model Pedido {
  id              String           @id @default(cuid())
  fecha           DateTime         @default(now())
  clienteId       String?
  cliente         String           // Nombre denormalizado
  estadoCuenta    String?          // OK, DEUDA_PENDIENTE
  gasId           String
  gas             Gas              @relation(fields: [gasId], references: [id])
  operacionEnvase String           // CANJE, VENTA_NUEVO
  phVigente       Boolean?         // null si es venta nueva
  phObservacion   String?
  total           Decimal   @default(0)
  estado          EstadoPedido     @default(PENDIENTE)
  observaciones   String?
  items           PedidoItem[]
  cilindros       PedidoCilindro[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([clienteId])
  @@index([estado])
  @@index([fecha])
  @@index([gasId])
}

model PedidoItem {
  id        String @id @default(cuid())
  pedidoId  String
  pedido    Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  concepto  String
  monto     Decimal
}

model TipoOperacionPedido {
  id        String   @id @default(cuid())
  nombre    String   @unique // "Con envase", "Sin envase", etc.
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PedidoCilindro {
  id          String   @id @default(cuid())
  pedidoId    String
  pedido      Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  numeroSerie String
  gasCodigo   String?  // Denormalizado: AR, O2, etc.
  verified    Boolean  @default(false) // Si el cilindro existe en inventario
  createdAt   DateTime @default(now())
}

model ClienteAcceso {
  id         String   @id @default(cuid())
  clienteId  String   @unique
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario    String   @unique
  password   String
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Rol {
  id          String    @id @default(cuid())
  nombre      String    @unique // admin, deposito, reparto, facturacion, auditor
  descripcion String?
  createdAt   DateTime  @default(now())
  usuarios    Usuario[]
}

model Usuario {
  id          String   @id @default(cuid())
  nombre      String
  direccion   String?
  telefono    String?
  ciudad      String?
  provincia   String?
  lat         Float?
  lng         Float?
  email       String?
  nivelAcceso Int      @default(1)
  usuario     String   @unique
  password    String
  activo      Boolean  @default(true)
  rolId       String?
  rol         Rol?     @relation(fields: [rolId], references: [id])
  rutasAsignadas Ruta[] @relation("ConductorRutas") // Rutas donde es conductor
  sesiones    SesionConductor[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Observacion {
  id          String              @id @default(cuid())
  tipo        String              // IMAGEN, VIDEO, NOTA, AUDIO
  titulo      String?
  descripcion String?             // texto asociado
  audioUrl    String?             // URL de audio grabado
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdBy   String?             // usuario que la creó
  archivos    ObservacionArchivo[]
}

model ObservacionArchivo {
  id             String      @id @default(cuid())
  observacionId  String
  observacion    Observacion @relation(fields: [observacionId], references: [id], onDelete: Cascade)
  tipo           String      // IMAGE, VIDEO
  nombre         String?
  datos          String      // base64 del archivo (legacy)
  archivoUrl     String?     // URL del archivo en S3/objetos
  createdAt   DateTime @default(now())
}

model Vehiculo {
  id                String                   @id @default(cuid())
  codigo            String                   @unique
  patente           String                   @unique
  marca             String
  modelo            String
  anio              Int
  vin               String?
  numeroMotor       String?
  tipo              TipoVehiculo
  combustible       CombustibleVehiculo
  capacidad         String?
  kmActual          Int                      @default(0)
  horometroActual   Int?
  estado            EstadoVehiculo           @default(ACTIVO)
  areaAsignada      String?
  conductorAsignado String?
  centroCosto       String?
  fechaAdquisicion  DateTime?
  valorCompra       Float?
  vidaUtilAnios     Int?
  fechaBaja         DateTime?

  // ============ CONFIGURACIÓN DE CARGA ============
  largoCajaCm       Float?   // Largo útil de la caja
  anchoCajaCm       Float?   // Ancho útil de la caja
  altoCajaCm        Float?   // Alto útil de la caja (para orientacion PARADOS)
  maxTubos          Int?     // Capacidad máxima de tubos
  orientacionTubos  OrientacionTubos         @default(PARADOS)
  costoPorKm        Float?   // Costo operativo por km (combustible + mantenimiento)

  rutas             Ruta[]
  ubicaciones       UbicacionGPS[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  mantenimientos    MantenimientoVehiculo[]
  cargasCombustible CargaCombustible[]
  documentos        DocumentoVehiculo[]
  sesionesCarga     CargaVehiculo[]

  @@index([estado])
  @@index([tipo])
}

model CargaVehiculo {
  id          String               @id @default(cuid())
  vehiculoId  String
  vehiculo    Vehiculo             @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  fecha       DateTime             @default(now())
  estado      EstadoCargaVehiculo @default(ACTIVA) // ACTIVA, COMPLETADA, CANCELADA
  createdAt   DateTime             @default(now())
  items       CargaVehiculoItem[]
}

model CargaVehiculoItem {
  id            String         @id @default(cuid())
  cargaId       String
  carga         CargaVehiculo  @relation(fields: [cargaId], references: [id], onDelete: Cascade)
  cylinderId    String
  cylinder      Cylinder       @relation(fields: [cylinderId], references: [id])
  posicion      Int            // Número de posición en la caja (1-based)
  createdAt     DateTime       @default(now())

  @@unique([cargaId, cylinderId])
  @@unique([cargaId, posicion])
}

model MantenimientoVehiculo {
  id            String   @id @default(cuid())
  vehiculoId    String
  vehiculo      Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  tipo          TipoMantenimientoVehiculo // PREVENTIVO, CORRECTIVO, PREDICTIVO
  fecha         DateTime
  kmActual      Int?
  descripcion   String
  costo         Float?
  taller        String?
  responsable   String?
  estado        EstadoMantenimiento       @default(PENDIENTE)
  observaciones String?
  createdAt     DateTime @default(now())
}

model CargaCombustible {
  id         String   @id @default(cuid())
  vehiculoId String
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  fecha      DateTime
  litros     Float
  costo      Float?
  kmActual   Int?
  rendimiento Float?
  tipo       TipoCargaCombustible @default(CARGA) // CARGA, CARGA_ELECTRICA
  createdAt     DateTime @default(now())
}

model DocumentoVehiculo {
  id               String   @id @default(cuid())
  vehiculoId       String
  vehiculo         Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  tipo             TipoDocumentoVehicular
  numero           String?
  fechaEmision     DateTime?
  fechaVencimiento DateTime?
  estado           EstadoDocumentoVehiculo @default(VIGENTE)
  observaciones    String?
  createdAt        DateTime @default(now())
}

// ============ DEPÓSITO / RFID STOCK ============

model ZonaLectura {
  id          String   @id @default(cuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  tipo        TipoZonaLectura // VACIOS, LLENOS, SALIDA_REPARTO, ENVIO_CARGA, RECEPCION_CARGA, MANTENIMIENTO, BAJA
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lectores    LectorIoT[]
  eventos     EventoRFID[]
  sesiones    SesionLecturaRFID[]
}

model LectorIoT {
  id            String      @id @default(cuid())
  codigo        String      @unique
  nombre        String
  tipo          TipoLector      // ESP32, RPI, GATEWAY
  ip            String?
  zonaLecturaId String
  zona          ZonaLectura @relation(fields: [zonaLecturaId], references: [id])
  activo        Boolean     @default(true)
  ultimoHeartbeat DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  eventos       EventoRFID[]
  sesiones      SesionLecturaRFID[]
}

model TagRFID {
  id                String       @id @default(cuid())
  tid               String       @unique // TID del chip RFID
  cylinderId        String?
  cylinder          Cylinder?    @relation(fields: [cylinderId], references: [id])
  fechaAsociacion   DateTime?
  activo            Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  eventos           EventoRFID[]
  sesiones          SesionLecturaRFID[]
}

model EventoRFID {
  id            String      @id @default(cuid())
  tid           String
  tag           TagRFID?    @relation(fields: [tid], references: [tid])
  cylinderId    String?
  lectorId      String
  lector        LectorIoT   @relation(fields: [lectorId], references: [id])
  zonaId        String
  zona          ZonaLectura @relation(fields: [zonaId], references: [id])
  timestamp     DateTime    @default(now())
  estadoAnterior String?
  estadoNuevo   String?
  origen        String      @default("AUTOMATICO") // AUTOMATICO, MANUAL
  usuario       String?
  observacion   String?
  createdAt     DateTime    @default(now())
  movimientosStock MovimientoStock[]
}

model SesionLecturaRFID {
  id            String      @id @default(cuid())
  lectorId      String
  lector        LectorIoT   @relation(fields: [lectorId], references: [id])
  zonaId        String
  zona          ZonaLectura @relation(fields: [zonaId], references: [id])
  tid           String      // TID del tag leído
  tag           TagRFID?    @relation(fields: [tid], references: [tid])
  cylinderId    String?
  cylinder      Cylinder?   @relation(fields: [cylinderId], references: [id])
  inicio        DateTime    @default(now())
  fin           DateTime?
  conteo        Int         @default(1) // cantidad de lecturas en esta sesión
  ultimaLectura DateTime    @default(now())
  procesado     Boolean     @default(false)
  estadoAnterior String?
  estadoNuevo   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model StockGas {
  id          String   @id @default(cuid())
  gasId       String   @unique
  gas         Gas      @relation(fields: [gasId], references: [id])
  llenos      Int      @default(0)
  vacios      Int      @default(0)
  enReparto   Int      @default(0)
  enCarga     Int      @default(0)
  mantenimiento Int    @default(0)
  baja        Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model MovimientoStock {
  id            String   @id @default(cuid())
  gasId         String
  gas           Gas      @relation(fields: [gasId], references: [id])
  tipo          String   // ENTRADA, SALIDA, TRANSFERENCIA
  cantidad      Int
  estadoAnterior String?
  estadoNuevo   String?
  eventoRfidId  String?
  eventoRfid    EventoRFID? @relation(fields: [eventoRfidId], references: [id])
  usuario       String?
  observacion   String?
  createdAt     DateTime @default(now())

  @@index([gasId, createdAt])
  @@index([tipo])
}

model Reparto {
  id            String   @id @default(cuid())
  codigo        String   @unique
  fecha         DateTime @default(now())
  clienteId     String?
  cliente       String?  // Denormalizado
  vehiculoId    String?
  estado        EstadoReparto @default(PENDIENTE)
  origenZonaId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ CABINA INTELIGENTE ============

model Cabina {
  id          String          @id @default(cuid())
  codigo      String          @unique
  nombre      String
  ubicacion   String?
  activo      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  sensores    SensorCabina[]
  validaciones ValidacionCabina[]
  alertas     Alerta[]
  eventos     EventoTrazabilidad[]
  lecturasPeso LecturaPeso[]
  evidenciasFoto EvidenciaFoto[]
}

model SensorCabina {
  id            String   @id @default(cuid())
  cabinaId      String
  cabina        Cabina   @relation(fields: [cabinaId], references: [id], onDelete: Cascade)
  tipo          String   // RFID, BALANZA, CAMARA, UPS
  codigo        String
  configuracion String?  // JSON con config específica
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LecturaPeso {
  id          String   @id @default(cuid())
  cabinaId    String
  cabina      Cabina   @relation(fields: [cabinaId], references: [id])
  cylinderId  String?
  cylinder    Cylinder? @relation(fields: [cylinderId], references: [id])
  pesoKg      Float
  fecha       DateTime @default(now())
  sensorId    String?  // Sensor que registró la lectura
  createdAt   DateTime @default(now())
  validaciones ValidacionCabina[]
}

model EvidenciaFoto {
  id          String   @id @default(cuid())
  cabinaId    String
  cabina      Cabina   @relation(fields: [cabinaId], references: [id])
  cylinderId  String?
  cylinder    Cylinder? @relation(fields: [cylinderId], references: [id])
  fecha       DateTime @default(now())
  imagen      String   // base64 (legacy)
  imagenUrl   String?  // URL de la imagen en S3/objetos
  createdAt   DateTime @default(now())
  validaciones ValidacionCabina[]
}

model ValidacionCabina {
  id              String   @id @default(cuid())
  cabinaId        String
  cabina          Cabina   @relation(fields: [cabinaId], references: [id])
  cylinderId      String?
  cylinder        Cylinder? @relation(fields: [cylinderId], references: [id])
  eventoRfidId    String?
  lecturaPesoId   String?
  lecturaPeso     LecturaPeso? @relation(fields: [lecturaPesoId], references: [id])
  evidenciaFotoId String?
  evidenciaFoto   EvidenciaFoto? @relation(fields: [evidenciaFotoId], references: [id])
  pesoRealKg      Float?
  pesoEsperadoKg  Float?
  diagnostico     DiagnosticoValidacion @default(OK) // OK, INCONSISTENCIA, NO_REGISTRADO, SOSPECHOSO
  estadoFinal     String?
  alertaGenerada  Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model ReglaPeso {
  id          String   @id @default(cuid())
  gasId       String   @unique
  gas         Gas      @relation(fields: [gasId], references: [id])
  pesoMinKg   Float?
  pesoMaxKg   Float?
  pesoTaraKg  Float?
  pesoLlenoKg Float?
  updatedAt   DateTime @updatedAt
}

model EventoTrazabilidad {
  id          String   @id @default(cuid())
  cabinaId    String
  cabina      Cabina   @relation(fields: [cabinaId], references: [id])
  cylinderId  String?
  cylinder    Cylinder? @relation(fields: [cylinderId], references: [id])
  tipo        String   // PASO_CABINA, VALIDACION, ALERTA, INGRESO, EGRESO
  descripcion String?
  fecha       DateTime @default(now())
  usuario     String?
  createdAt   DateTime @default(now())
}

model Alerta {
  id          String   @id @default(cuid())
  tipo        TipoAlerta
  cabinaId    String?
  cabina      Cabina?  @relation(fields: [cabinaId], references: [id])
  cylinderId  String?
  cylinder    Cylinder? @relation(fields: [cylinderId], references: [id])
  mensaje     String
  nivel       NivelAlerta
  resuelta    Boolean  @default(false)
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([cylinderId])
  @@index([resuelta])
  @@index([nivel])
}

model AuditLog {
  id        String   @id @default(cuid())
  accion    AccionAudit  // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entidad   String   // Cylinder, Cliente, Pedido, Factura, Usuario, etc.
  entidadId String?  // ID del registro afectado
  usuario   String?  // usuario que ejecutó la acción
  detalle   String?  // JSON con datos relevantes del cambio
  direccionIp String?
  createdAt DateTime @default(now())

  @@index([entidad, entidadId])
  @@index([createdAt])
}

// ============ SPRINT 5 — RUTAS Y LOGÍSTICA ============

model Geocerca {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  lat         Float    // Centro de la geocerca (para UI)
  lng         Float
  radioMetros Float    // Radio en metros (círculo simple)
  polygon     String?  // JSON opcional: [[lat,lng],[lat,lng],...] para polígono
  color       String   @default("#3b82f6")
  activa      Boolean  @default(true)
  tipo        TipoGeocerca   @default(DEPOSITO) // DEPOSITO, CLIENTE, RESTRINGIDA, ENTREGA
  regla       String?  // JSON: reglas al entrar/salir (ej: notificar, alertar, bloquear)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UbicacionGPS {
  id         String    @id @default(cuid())
  rutaId     String
  ruta       Ruta      @relation(fields: [rutaId], references: [id], onDelete: Cascade)
  vehiculoId String?   // FK → Vehiculo (opcional, tracking por vehículo)
  vehiculo   Vehiculo? @relation(fields: [vehiculoId], references: [id])
  lat        Float
  lng        Float
  velocidad  Float?    // Km/h en el momento del ping
  rumbo      Float?    // Grados (0=N, 90=E)
  precision  Float?    // Metros de precisión del GPS
  fuente     FuenteGPS    @default(GPS) // GPS, MANUAL, SIMULADO
  metadata   String?   // JSON extra
  createdAt  DateTime  @default(now())

  @@index([rutaId, createdAt])
  @@index([vehiculoId])
}

model SesionConductor {
  id              String   @id @default(cuid())
  conductorId     String   // FK → Usuario
  conductor       Usuario  @relation(fields: [conductorId], references: [id], onDelete: Cascade)
  rutaId          String?  // Ruta activa actual
  ruta            Ruta?    @relation(fields: [rutaId], references: [id])
  token           String   @unique // Token de sesión
  estaEnLinea     Boolean  @default(true)
  lat             Float?   // Última ubicación conocida
  lng             Float?
  velocidad       Float?   // Última velocidad
  ultimoHeartbeat DateTime @default(now())
  navegadorInfo   String?  // User agent
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TrafficHistory {
  id         String   @id @default(cuid())
  tramoHash  String   // Hash de origen->destino
  origenLat  Float
  origenLng  Float
  destLat    Float
  destLng    Float
  hora       Int      // 0-23
  diaSemana  Int      // 0=domingo, 6=sábado
  velocidad  Float    // Velocidad promedio km/h
  muestras   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tramoHash, hora, diaSemana])
}

// ============ LECTURA CELULAR — MÓDULO MÓVIL ============

enum TipoIdentificador {
  UHF_EPC
  UHF_TID
  NFC_UID
  NFC_TOKEN
  QR_TOKEN
}

enum OrigenLectura {
  PORTAL_UHF
  HANDHELD_UHF
  CELULAR_NFC
  CELULAR_QR
  CLIENTE_MOVIL
}

enum AccionEventoTubo {
  CONSULTA
  CONTROL
  CONTROL_EXTERNO
  PEDIDO_REPOSICION
  RETIRO
  NOVEDAD
  ENTREGA
  DEVOLUCION
}

enum EstadoPedidoLectura {
  BORRADOR
  ENVIADO
  VALIDADO
  EN_PREPARACION
  EN_REPARTO
  ENTREGADO
  CERRADO
  RECHAZADO
}

enum AccionItemPedidoLectura {
  REPONER
  RETIRAR
  MANTENER
  REPORTAR
}

model IdentificadorTubo {
  id              String             @id @default(cuid())
  cylinderId      String
  cylinder        Cylinder           @relation(fields: [cylinderId], references: [id], onDelete: Cascade)
  tipo            TipoIdentificador
  valor           String             @unique
  activo          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([cylinderId])
  @@index([tipo])
  @@index([valor])
}

model EventoTubo {
  id              String             @id @default(cuid())
  cylinderId      String
  cylinder        Cylinder           @relation(fields: [cylinderId], references: [id], onDelete: Cascade)
  fechaHora       DateTime           @default(now())
  origen          OrigenLectura
  readSource      String?
  accion          AccionEventoTubo
  usuarioId       String?
  usuarioNombre   String?
  clienteId       String?
  clienteNombre   String?
  latitud         Float?
  longitud        Float?
  estadoAnterior  String?
  estadoNuevo     String?
  observacion     String?
  fotoUrl         String?
  hashEvento      String?
  createdAt       DateTime           @default(now())

  @@index([cylinderId])
  @@index([clienteId])
  @@index([fechaHora])
}

model PedidoLectura {
  id              String                @id @default(cuid())
  clienteId       String?
  clienteNombre   String?
  obraId          String?
  obraNombre      String?
  usuarioId       String?
  usuarioNombre   String?
  estado          EstadoPedidoLectura   @default(BORRADOR)
  prioridad       String                @default("NORMAL")
  observacion     String?
  contactoObra    String?
  fechaCreacion   DateTime              @default(now())
  fechaEnvio      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  items           PedidoLecturaItem[]

  @@index([clienteId])
  @@index([estado])
  @@index([fechaCreacion])
}

model PedidoLecturaItem {
  id              String                 @id @default(cuid())
  pedidoId        String
  pedido          PedidoLectura          @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  cylinderId      String?
  cylinder        Cylinder?              @relation(fields: [cylinderId], references: [id])
  codigoTubo      String?
  tipoGas         String?
  capacidad       Int?
  accion          AccionItemPedidoLectura
  cantidad        Int                    @default(1)
  observacion     String?
  fotoUrl         String?
  createdAt       DateTime               @default(now())

  @@index([pedidoId])
}

// ============ AUDITORÍA DE RUTAS ============
model RouteCalcLog {
  id              String   @id @default(cuid())
  rutaId          String?
  userName        String?
  paradaCount     Int
  engine          String   // OR_TOOLS | TSP | NONE
  source          String   // OSRM_LOCAL | OSRM_PUBLIC | HAVERSINE_ESTIMATED | NONE
  distanceKm      Float
  durationMin     Int
  isRealRoute     Boolean  @default(false)
  error           String?
  createdAt       DateTime @default(now())

  @@index([rutaId])
  @@index([createdAt])
}

// ============ IDEMPOTENCIA ============
model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  response  String   // JSON del resultado
  status    Int      @default(200) // Código HTTP de la respuesta original
  expiresAt DateTime // TTL: se limpia después de este tiempo
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ─── Phase 5: Historical migration models ───────────────────────────────

model ComprobanteHistorico {
  id              String                    @id @default(cuid())
  fecha           DateTime
  fechaVto        DateTime?
  tipo            String                    // Fact A, Fact B, NCred A, NDeb A, Pedido X, Remi X, etc.
  letra           String?                   // A, B, X, etc.
  puntoVenta      String?
  numero          String?
  cbteCompleto    String                    // "Fact A 0001-00017220"
  clienteId       String?
  clienteNombre   String
  clienteDoc      String?
  clienteDocTipo  Int?
  netoGravado     Decimal                   @default(0)
  netoExento      Decimal                   @default(0)
  iva21           Decimal                   @default(0)
  iva105          Decimal                   @default(0)
  iva27           Decimal                   @default(0)
  percepcionIibb  Decimal                   @default(0)
  total           Decimal                   @default(0)
  vendedorNombre  String?
  observaciones   String?
  items           ComprobanteItemHistorico[]
  createdAt       DateTime                  @default(now())

  @@index([clienteId])
  @@index([fecha])
  @@index([cbteCompleto])
}

model ComprobanteItemHistorico {
  id              String   @id @default(cuid())
  comprobanteId   String
  comprobante     ComprobanteHistorico @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  codigoProducto  String?
  descripcion     String
  cantidad        Decimal  @default(0)
  precioUnitario  Decimal  @default(0)
  descuento       Decimal  @default(0)
  subtotal        Decimal  @default(0)
  alicuotaIva     Decimal  @default(0)
  importeIva      Decimal  @default(0)
  createdAt       DateTime @default(now())

  @@index([comprobanteId])
}

model CuentaCorrienteMovimiento {
  id                 String   @id @default(cuid())
  clienteId          String?
  clienteNombre      String?
  codigoClienteLegacy Int?    // CTA_CLIE de GR2_510
  comprobante        String   // "Fact A 0003-00000001"
  fecha              DateTime
  fechaVto           DateTime?
  cuota              String?  // "001/001"
  debe               Decimal  @default(0)
  haber              Decimal  @default(0)
  saldo              Decimal  @default(0)
  pagado             Decimal  @default(0)
  operador           String?
  createdAt          DateTime @default(now())

  @@index([clienteId])
  @@index([codigoClienteLegacy])
  @@index([fecha])
  @@index([comprobante])
}

// ============ GERENCIA / MERCADO LIBRE & MERCADO PAGO ============

model SellerAccount {
  id              String   @id @default(cuid())
  sellerId        Int
  siteId          String   // MLA
  accessToken     String   // cifrado
  refreshToken    String   // cifrado
  tokenExpiresAt  DateTime
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders          MlOrder[]
  items           MlItem[]

  @@unique([sellerId, siteId])
}

model MlOrder {
  id              String   @id @default(cuid())
  orderId         BigInt   @unique
  packId          BigInt?
  sellerId        Int
  sellerAccountId String
  sellerAccount   SellerAccount @relation(fields: [sellerAccountId], references: [id])
  status          String
  totalAmount     Decimal
  buyerNick       String?
  dateCreated     DateTime
  dateClosed      DateTime?
  tags            String?  // JSON array
  raw             Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           MlOrderItem[]
  payment         MpPayment?
  shipment        MlShipment?
  claim           MlClaimReturn?

  @@index([sellerAccountId])
  @@index([dateCreated])
  @@index([status])
}

model MlOrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     MlOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId    String
  title     String?
  quantity  Int
  unitPrice Decimal
  saleFee   Decimal?

  @@index([orderId])
}

model MlShipment {
  id          String   @id @default(cuid())
  shipmentId  BigInt   @unique
  orderId     BigInt?
  packId      BigInt?
  mlOrderId   String?  @unique
  mlOrder     MlOrder? @relation(fields: [mlOrderId], references: [id])
  status      String
  substatus   String?
  carrier     String?
  tracking    String?
  dateCreated DateTime
  dateShipped DateTime?
  dateDelivered DateTime?

  @@index([status])
}

model MlClaimReturn {
  id          String   @id @default(cuid())
  claimId     BigInt   @unique
  mlOrderId   String?  @unique
  mlOrder     MlOrder? @relation(fields: [mlOrderId], references: [id])
  type        String   // claim, return, mediation
  status      String
  reason      String?
  amount      Decimal?
  dateCreated DateTime
  dateClosed  DateTime?

  @@index([type])
  @@index([status])
}

model MlQuestion {
  id          String   @id @default(cuid())
  questionId  BigInt   @unique
  itemId      String
  text        String
  answer      String?
  status      String   // ANSWERED, UNANSWERED, BANNED
  dateCreated DateTime

  @@index([status])
}

model MlItem {
  id              String   @id @default(cuid())
  itemId          String   @unique
  sellerAccountId String
  sellerAccount   SellerAccount @relation(fields: [sellerAccountId], references: [id])
  title           String
  price           Decimal
  availableQty    Int
  soldQty         Int
  status          String   // active, paused, closed
  dateCreated     DateTime
  dateUpdated     DateTime

  @@index([sellerAccountId])
  @@index([status])
}

model MpPayment {
  id            String   @id @default(cuid())
  paymentId     BigInt   @unique
  mlOrderId     String?  @unique
  mlOrder       MlOrder? @relation(fields: [mlOrderId], references: [id])
  status        String
  amount        Decimal
  fee           Decimal
  netReceived   Decimal
  externalRef   String?
  dateCreated   DateTime
  dateApproved  DateTime?
  raw           Json?

  @@index([mlOrderId])
  @@index([status])
}

model MpAccountMovement {
  id          String   @id @default(cuid())
  sourceId    String
  externalRef String?
  type        String   // payment, release, fee, refund, chargeback, withdrawal
  amount      Decimal
  balance     Decimal?
  date        DateTime
  raw         Json?

  @@index([sourceId])
  @@index([date])
  @@index([type])
}

model MpReleaseReport {
  id          String   @id @default(cuid())
  sourceId    String
  externalRef String?
  releaseDate DateTime
  amount      Decimal
  subtotal    Decimal?
  status      String

  @@index([sourceId])
  @@index([releaseDate])
}

model ConciliacionOperacion {
  id            String   @id @default(cuid())
  mlOrderId     String?
  mpPaymentId   String?
  fecha         DateTime
  importeOrden  Decimal
  importePago   Decimal
  importeNeto   Decimal?
  comision      Decimal?
  diferencia    Decimal
  alerta        String?  // ORDEN_SIN_PAGO, PAGO_SIN_ORDEN, DIFERENCIA, DINERO_RETENIDO, etc.
  status        String   // OK, ALERTA, CRITICO
  createdAt     DateTime @default(now())

  @@index([mlOrderId])
  @@index([mpPaymentId])
  @@index([alerta])
  @@index([status])
}

model Articulo {
  ART_CODI  Int      @id
  ART_DET1  String
  ART_COD1  String?
  ART_COD2  String?
  ART_COD3  String?
  ART_PRE1  Float?
  ART_PRE2  Float?
  ART_PRE3  Float?
  ART_PRE4  Float?
  ART_COST  Float?
  ART_TIVA  Int?
  ART_STIN  Float?
  ART_SMIN  Float?
  ART_SMAX  Float?
  ART_UNID  String?
  ART_MARC  Int?
  ART_RUBR  Int?
  ART_SUBR  Int?
  ART_DPTO  Int?
  ART_DTO1  Float?
  ART_DTO2  Float?
  ART_DTO3  Float?
  ART_DTOG  Float?
  ART_LIST  Int?
  ART_OFER  Int?
  ART_POFE  Float?
  ART_FLET  Float?
  ART_OBS   String?
  ART_DET2  String?
  ART_DET3  String?
  ART_DET4  String?
  datos     Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Articulo")
}

model AuditoriaSincronizacion {
  id              String   @id @default(cuid())
  tipo            String   // ML_ORDERS, ML_SHIPMENTS, MP_PAYMENTS, MP_MOVEMENTS
  fechaInicio     DateTime
  fechaFin        DateTime?
  estado          String   // OK, ERROR, PARCIAL
  registrosNuevos Int      @default(0)
  registrosError  Int      @default(0)
  detalle         String?
  createdAt       DateTime @default(now())

  @@index([tipo])
  @@index([fechaInicio])
}
