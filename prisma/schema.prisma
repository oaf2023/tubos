model DocumentoNumerador {
  id                String   @id @default(cuid())
  tipoDocumento     TipoDocumentoComercial
  letra             String
  codigoComprobante String   @default("00")
  abreviatura       String
  puntoVenta        String
  ultimoNumero      Int      @default(0)
  fiscal            Boolean  @default(false)
  sinValidezFiscal  Boolean  @default(true)
  copias            String   @default("ORIGINAL,DUPLICADO")
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tipoDocumento, letra, puntoVenta])
  @@index([tipoDocumento])
}

model DocumentoComercial {
