  netoGravado              Decimal @default(0)
  iva21                    Decimal @default(0)
  iva105                   Decimal @default(0)
  iva27                    Decimal @default(0)
  iva5                     Decimal @default(0)
  iva25                    Decimal @default(0)
  iva0                     Decimal @default(0)
