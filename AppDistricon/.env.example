SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET=change-me-to-another-random-secret
JWT_EXPIRATION_HOURS=24

# SQLite database path (relative to backend/)
DATABASE_PATH=data/tubos.db

# Company info
COMPANY_NAME=AppDistricon
COMPANY_TAGLINE=Control Digital
COMPANY_BASE_CITY=San Nicolás de los Arroyos
COMPANY_BASE_PROVINCE=Buenos Aires
COMPANY_BASE_LAT=-33.3292
COMPANY_BASE_LNG=-60.2265

# Mercado Libre OAuth (real mode when MOCK=false)
MOCK_MERCADO_LIBRE=true
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_REDIRECT_URI=

# Mercado Pago (real mode when MOCK=false)
MOCK_MERCADO_PAGO=true
MERCADOPAGO_ACCESS_TOKEN=

# OSRM routing server
OSRM_BASE_URL=https://router.project-osrm.org

# OR-Tools microservice (optional)
OR_TOOLS_URL=http://localhost:8000

# File uploads
UPLOAD_DIR=public/uploads

# Event hash salt (for mobile tube events)
EVENT_HASH_SALT=change-this-salt
